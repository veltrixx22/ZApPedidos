rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // TODO: This no-login adminCode access is for MVP validation only. Before scaling, replace with Firebase Auth and hashed admin codes or proper owner authentication.
    // Public MVP access so the app can launch without Firebase Authentication.
    match /stores/{storeId} {
      allow read: if true;
      allow create, update: if isValidId(storeId) &&
        request.resource.data.keys().hasAll(['businessName', 'whatsappNumber', 'slug', 'adminCode']) &&
        request.resource.data.businessName is string &&
        request.resource.data.whatsappNumber is string &&
        request.resource.data.slug is string;
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidId(productId) &&
        request.resource.data.storeId is string &&
        request.resource.data.name is string &&
        request.resource.data.price is number &&
        request.resource.data.category is string;
      allow delete: if true;
    }
  }
}
